Project RecallStack {
  database_type: 'PostgreSQL'
}

Enum topic_kind {
  topic
  pattern
}

Enum content_type {
  problem
  concept
  pattern
  article
  architecture
  case_study
}

Enum difficulty_level {
  beginner
  easy
  medium
  hard
  expert
}

Enum publication_status {
  draft
  in_review
  published
  archived
}

Enum block_type {
  recognize
  remember
  invariant
  approach
  code
  mistake
  warning
  diagram
  table
  architecture_flow
  quiz
  related_content
  external_link
}

Enum content_relation_type {
  prerequisite
  related
  alternative
}

Enum learning_status {
  new
  learning
  attempted
  confident
  mastered
}

Enum practice_outcome {
  solved_independently
  solved_with_hint
  understood_not_coded
  pattern_not_identified
  skipped
}

Enum note_kind {
  note
  mistake
  insight
}

Enum review_rating {
  again
  hard
  good
  easy
}

Enum mutation_operation {
  insert
  update
  delete
}

Enum mutation_status {
  received
  applied
  rejected
}

Enum change_operation {
  upsert
  delete
}

Enum release_status {
  building
  published
  retired
}

// ============================================================
// IDENTITY AND AUTHORIZATION
// ============================================================

Table auth.users {
  id uuid [pk]
}

Table profiles {
  id uuid [pk]
  display_name varchar(120)
  avatar_url text
  timezone varchar(64) [not null, default: 'UTC']
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

}

Table roles {
  id smallint [pk, increment]
  code varchar(80) [not null, unique]
  description text

}

Table profile_role_grants {
  id bigint [pk, increment]
  profile_id uuid [not null]
  role_id smallint [not null]
  granted_at timestamptz [not null, default: `now()`]
  granted_by uuid
  revoked_at timestamptz
  revoked_by uuid


  checks {
    `revoked_at IS NULL OR revoked_at >= granted_at` [name: 'chk_role_grant_revoke_time']
  }

}

// ============================================================
// CONTENT TAXONOMY
// ============================================================

Table domains {
  id uuid [pk, default: `gen_random_uuid()`]
  slug varchar(100) [not null, unique]
  name varchar(160) [not null]
  description text
  sort_order int [not null, default: 0]
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

}

Table categories {
  id uuid [pk, default: `gen_random_uuid()`]
  domain_id uuid [not null]
  parent_category_id uuid
  slug varchar(120) [not null]
  name varchar(160) [not null]
  description text
  sort_order int [not null, default: 0]
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (domain_id, id) [unique]
    (domain_id, slug) [unique]
  }

  checks {
    `parent_category_id IS NULL OR parent_category_id <> id` [name: 'chk_category_not_self_parent']
  }

}

Table topics {
  id uuid [pk, default: `gen_random_uuid()`]
  domain_id uuid [not null]
  kind topic_kind [not null, default: 'topic']
  slug varchar(120) [not null]
  name varchar(160) [not null]
  description text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (domain_id, id) [unique]
    (domain_id, slug) [unique]
  }
}

Table topic_categories {
  domain_id uuid [not null]
  topic_id uuid [not null]
  category_id uuid [not null]
  sort_order int [not null, default: 0]

  indexes {
    (topic_id, category_id) [pk]
  }

}

// ============================================================
// CONTENT AUTHORING AND PUBLICATION
// ============================================================

Table content_items {
  id uuid [pk, default: `gen_random_uuid()`]
  domain_id uuid [not null]
  slug varchar(160) [not null]
  type content_type [not null]
  difficulty difficulty_level
  current_published_version_id uuid
  practice_resources_revision bigint [not null, default: 1]
  created_by uuid
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  archived_at timestamptz

  indexes {
    (domain_id, id) [unique]
    (domain_id, slug) [unique]
  }

  checks {
    `practice_resources_revision > 0` [name: 'chk_content_items_practice_resources_revision']
  }

}

Table content_item_categories {
  domain_id uuid [not null]
  content_item_id uuid [not null]
  category_id uuid [not null]
  sort_order int [not null, default: 0]

  indexes {
    (content_item_id, category_id) [pk]
  }

}

Table content_item_topics {
  domain_id uuid [not null]
  content_item_id uuid [not null]
  topic_id uuid [not null]
  is_primary boolean [not null, default: false]
  sort_order int [not null, default: 0]

  indexes {
    (content_item_id, topic_id) [pk]
  }

}

Table content_versions {
  id uuid [pk, default: `gen_random_uuid()`]
  content_item_id uuid [not null]
  version_number int [not null]
  status publication_status [not null, default: 'draft']
  title varchar(240) [not null]
  summary text
  search_document tsvector
  authored_by uuid
  reviewed_by uuid
  published_by uuid
  published_at timestamptz
  row_version bigint [not null, default: 1]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (content_item_id, id) [unique]
    (content_item_id, version_number) [unique]
  }

  checks {
    `version_number > 0` [name: 'chk_content_version_number_positive']
    `status <> 'published' OR (published_at IS NOT NULL AND published_by IS NOT NULL)` [name: 'chk_content_version_published_at']
    `row_version > 0` [name: 'chk_content_version_row_version']
  }

}

Table content_version_status_history {
  id bigint [pk, increment]
  content_version_id uuid [not null]
  from_status publication_status
  to_status publication_status [not null]
  changed_by uuid
  reason text
  changed_at timestamptz [not null, default: `now()`]


}

Table content_blocks {
  id uuid [pk, default: `gen_random_uuid()`]
  type block_type [not null]
  payload jsonb [not null]
  plain_text text
  content_hash varchar(64) [not null]
  created_by uuid
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (type, content_hash) [unique]
  }

  checks {
    `char_length(content_hash) = 64 AND content_hash ~ '^[0-9a-f]{64}$'` [name: 'chk_content_blocks_hash']
  }
}

Table content_version_blocks {
  content_version_id uuid [not null]
  content_block_id uuid [not null]
  position int [not null]
  heading varchar(240)

  indexes {
    (content_version_id, position) [pk]
    (content_version_id, content_block_id) [unique]
  }

  checks {
    `position >= 0` [name: 'chk_content_version_blocks_position']
  }
}

Table content_relations {
  source_content_item_id uuid [not null]
  target_content_item_id uuid [not null]
  relation_type content_relation_type [not null]
  sort_order int [not null, default: 0]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (source_content_item_id, target_content_item_id, relation_type) [pk]
  }

  checks {
    `source_content_item_id <> target_content_item_id` [name: 'chk_content_relation_not_self']
    `(relation_type NOT IN ('related', 'alternative')) OR (source_content_item_id < target_content_item_id)` [name: 'chk_content_relation_canonical_symmetric']
  }

}

Table practice_providers {
  id smallint [pk, increment]
  slug varchar(80) [not null, unique]
  name varchar(120) [not null]
  base_url text
  is_active boolean [not null, default: true]
}

Table practice_resources {
  id uuid [pk, default: `gen_random_uuid()`]
  content_item_id uuid [not null]
  provider_id smallint [not null]
  external_key varchar(255)
  url text [not null]
  url_hash varchar(64) [not null]
  title varchar(300)
  is_primary boolean [not null, default: false]
  sort_order int [not null, default: 0]
  archived_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (id, content_item_id) [unique]
    (id, provider_id) [unique]
    (content_item_id, provider_id, url_hash) [unique]
  }

  checks {
    `char_length(url_hash) = 64 AND url_hash ~ '^[0-9a-f]{64}$'` [name: 'chk_practice_resources_url_hash']
  }
}

Table catalog_releases {
  id uuid [pk, default: `gen_random_uuid()`]
  domain_id uuid [not null]
  release_number bigint [not null]
  status release_status [not null, default: 'building']
  published_at timestamptz
  published_by uuid
  retired_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (domain_id, id) [unique]
    (domain_id, release_number) [unique]
  }

  checks {
    `release_number > 0` [name: 'chk_catalog_release_number_positive']
    `status <> 'published' OR published_at IS NOT NULL` [name: 'chk_catalog_release_published_at']
    `retired_at IS NULL OR published_at IS NOT NULL` [name: 'chk_catalog_release_retire_after_publish']
  }

}

Table catalog_release_versions {
  domain_id uuid [not null]
  catalog_release_id uuid [not null]
  content_item_id uuid [not null]
  content_version_id uuid [not null]

  indexes {
    (catalog_release_id, content_item_id) [pk]
  }

}

// ============================================================
// LEARNING STATE AND ACTIVITY
// ============================================================

Table user_progress {
  user_id uuid [not null]
  content_item_id uuid [not null]
  status learning_status [not null, default: 'new']
  confidence smallint [not null, default: 0]
  last_opened_at timestamptz
  row_version bigint [not null, default: 1]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, content_item_id) [pk]
  }

  checks {
    `confidence BETWEEN 0 AND 100` [name: 'chk_user_progress_confidence']
    `row_version > 0` [name: 'chk_user_progress_row_version']
  }

}

Table bookmarks {
  user_id uuid [not null]
  content_item_id uuid [not null]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, content_item_id) [pk]
  }
}

Table practice_attempts {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null]
  content_item_id uuid [not null]
  practice_resource_id uuid
  provider_id smallint [not null]
  outcome practice_outcome [not null]
  duration_seconds int
  hint_used boolean [not null, default: false]
  confidence_before smallint
  confidence_after smallint
  attempted_at timestamptz [not null]
  created_at timestamptz [not null, default: `now()`]


  checks {
    `duration_seconds IS NULL OR duration_seconds >= 0` [name: 'chk_practice_attempt_duration']
    `confidence_before IS NULL OR confidence_before BETWEEN 0 AND 100` [name: 'chk_practice_attempt_conf_before']
    `confidence_after IS NULL OR confidence_after BETWEEN 0 AND 100` [name: 'chk_practice_attempt_conf_after']
  }

}

Table user_notes {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null]
  content_item_id uuid [not null]
  kind note_kind [not null]
  title varchar(240)
  body text [not null]
  row_version bigint [not null, default: 1]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz


  checks {
    `row_version > 0` [name: 'chk_user_note_row_version']
  }

}

Table activity_events {
  id bigint [pk, increment]
  user_id uuid [not null]
  content_item_id uuid
  event_type varchar(80) [not null]
  source_entity_type varchar(80)
  source_entity_id uuid
  metadata jsonb
  occurred_at timestamptz [not null, default: `now()`]


}

// ============================================================
// SPACED REVISION
// ============================================================

Table review_cards {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null]
  content_item_id uuid [not null]
  scheduler_name varchar(80) [not null, default: 'simple']
  scheduler_version varchar(40) [not null, default: '1']
  due_at timestamptz [not null]
  interval_days decimal(12,4) [not null, default: 0]
  stability decimal(12,6)
  difficulty decimal(12,6)
  review_count int [not null, default: 0]
  lapse_count int [not null, default: 0]
  last_reviewed_at timestamptz
  scheduler_state jsonb [not null, default: '{}']
  row_version bigint [not null, default: 1]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  suspended_at timestamptz

  indexes {
    (user_id, content_item_id) [unique]
    (id, user_id) [unique]
  }

  checks {
    `interval_days >= 0` [name: 'chk_review_card_interval']
    `review_count >= 0` [name: 'chk_review_card_review_count']
    `lapse_count >= 0` [name: 'chk_review_card_lapse_count']
    `row_version > 0` [name: 'chk_review_card_row_version']
  }

}

Table review_history {
  id bigint [pk, increment]
  review_event_id uuid [not null, default: `gen_random_uuid()`, unique]
  review_card_id uuid [not null]
  user_id uuid [not null]
  rating review_rating [not null]
  reviewed_at timestamptz [not null]
  response_time_ms int
  previous_due_at timestamptz
  next_due_at timestamptz [not null]
  interval_days_after decimal(12,4)
  scheduler_name varchar(80) [not null]
  scheduler_version varchar(40) [not null]
  scheduler_state_after jsonb
  created_at timestamptz [not null, default: `now()`]


  checks {
    `response_time_ms IS NULL OR response_time_ms >= 0` [name: 'chk_review_history_response_time']
    `interval_days_after IS NULL OR interval_days_after >= 0` [name: 'chk_review_history_interval']
  }

}

// ============================================================
// OFFLINE SYNC
// ============================================================

Table devices {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null]
  device_name varchar(160)
  platform varchar(40) [not null]
  app_version varchar(40)
  last_seen_at timestamptz
  registered_at timestamptz [not null, default: `now()`]
  revoked_at timestamptz

  indexes {
    (id, user_id) [unique]
  }
}

Table device_user_sync_state {
  device_id uuid [pk]
  last_user_cursor bigint [not null, default: 0]
  last_pull_at timestamptz
  last_push_at timestamptz
  full_resync_required boolean [not null, default: false]
  updated_at timestamptz [not null, default: `now()`]

  checks {
    `last_user_cursor >= 0` [name: 'chk_device_user_sync_cursor']
  }
}

Table device_catalog_sync_state {
  device_id uuid [not null]
  domain_id uuid [not null]
  last_catalog_cursor bigint [not null, default: 0]
  last_catalog_release_id uuid
  full_resync_required boolean [not null, default: false]
  last_pull_at timestamptz
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (device_id, domain_id) [pk]
  }

  checks {
    `last_catalog_cursor >= 0` [name: 'chk_device_catalog_sync_cursor']
  }
}

Table sync_mutations {
  mutation_id uuid [pk]
  user_id uuid [not null]
  device_id uuid [not null]
  entity_type varchar(80) [not null]
  entity_id uuid [not null]
  operation mutation_operation [not null]
  payload jsonb
  request_hash varchar(64) [not null]
  status mutation_status [not null, default: 'received']
  base_row_version bigint
  resulting_row_version bigint
  error_code varchar(80)
  received_at timestamptz [not null, default: `now()`]
  processed_at timestamptz
  expires_at timestamptz [not null]


  checks {
    `expires_at > received_at` [name: 'chk_sync_mutation_expiry']
    `processed_at IS NULL OR processed_at >= received_at` [name: 'chk_sync_mutation_processed_time']
    `(status = 'received' AND processed_at IS NULL) OR (status = 'applied' AND processed_at IS NOT NULL) OR (status = 'rejected' AND processed_at IS NOT NULL AND error_code IS NOT NULL)` [name: 'chk_sync_mutation_status_consistency']
    `base_row_version IS NULL OR base_row_version > 0` [name: 'chk_sync_mutation_base_version']
    `resulting_row_version IS NULL OR resulting_row_version > 0` [name: 'chk_sync_mutation_result_version']
    `char_length(request_hash) = 64 AND request_hash ~ '^[0-9a-f]{64}$'` [name: 'chk_sync_mutation_request_hash']
  }

}

Table user_sync_counters {
  user_id uuid [pk]
  last_cursor bigint [not null, default: 0]
  updated_at timestamptz [not null, default: `now()`]

  checks {
    `last_cursor >= 0` [name: 'chk_user_sync_counter_nonnegative']
  }

}

Table user_sync_change_log {
  user_id uuid [not null]
  cursor bigint [not null]
  entity_type varchar(80) [not null]
  entity_id uuid [not null]
  operation change_operation [not null]
  entity_version bigint
  changed_at timestamptz [not null, default: `now()`]
  retain_until timestamptz [not null]

  indexes {
    (user_id, cursor) [pk]
  }

  checks {
    `cursor > 0` [name: 'chk_user_sync_change_cursor_positive']
    `retain_until > changed_at` [name: 'chk_user_sync_change_retention']
  }

}

Table catalog_sync_counters {
  domain_id uuid [pk]
  last_cursor bigint [not null, default: 0]
  updated_at timestamptz [not null, default: `now()`]

  checks {
    `last_cursor >= 0` [name: 'chk_catalog_sync_counter_nonnegative']
  }

}

Table catalog_sync_change_log {
  domain_id uuid [not null]
  cursor bigint [not null]
  entity_type varchar(80) [not null]
  entity_id uuid [not null]
  operation change_operation [not null]
  entity_version bigint
  changed_at timestamptz [not null, default: `now()`]
  retain_until timestamptz [not null]

  indexes {
    (domain_id, cursor) [pk]
  }

  checks {
    `cursor > 0` [name: 'chk_catalog_sync_change_cursor_positive']
    `retain_until > changed_at` [name: 'chk_catalog_sync_change_retention']
  }

}

// ============================================================
// RELATIONSHIPS
// ============================================================

Ref: auth.users.id - profiles.id [delete: cascade]

Ref: profile_role_grants.profile_id > profiles.id [delete: cascade]
Ref: profile_role_grants.role_id > roles.id [delete: restrict]
Ref: profile_role_grants.granted_by > profiles.id [delete: set null]
Ref: profile_role_grants.revoked_by > profiles.id [delete: set null]

Ref: categories.domain_id > domains.id [delete: restrict]
Ref: categories.(domain_id, parent_category_id) > categories.(domain_id, id) [delete: restrict]

Ref: topics.domain_id > domains.id [delete: restrict]
Ref: topic_categories.(domain_id, topic_id) > topics.(domain_id, id) [delete: cascade]
Ref: topic_categories.(domain_id, category_id) > categories.(domain_id, id) [delete: cascade]

Ref: content_items.domain_id > domains.id [delete: restrict]
Ref: content_items.created_by > profiles.id [delete: set null]

Ref: content_versions.content_item_id > content_items.id [delete: cascade]
Ref: content_items.(id, current_published_version_id) > content_versions.(content_item_id, id) [delete: restrict]

Ref: content_item_categories.(domain_id, content_item_id) > content_items.(domain_id, id) [delete: cascade]
Ref: content_item_categories.(domain_id, category_id) > categories.(domain_id, id) [delete: cascade]

Ref: content_item_topics.(domain_id, content_item_id) > content_items.(domain_id, id) [delete: cascade]
Ref: content_item_topics.(domain_id, topic_id) > topics.(domain_id, id) [delete: cascade]

Ref: content_versions.authored_by > profiles.id [delete: set null]
Ref: content_versions.reviewed_by > profiles.id [delete: set null]
Ref: content_version_status_history.content_version_id > content_versions.id [delete: cascade]
Ref: content_version_status_history.changed_by > profiles.id [delete: set null]

Ref: content_blocks.created_by > profiles.id [delete: set null]
Ref: content_version_blocks.content_version_id > content_versions.id [delete: cascade]
Ref: content_version_blocks.content_block_id > content_blocks.id [delete: restrict]

Ref: content_relations.source_content_item_id > content_items.id [delete: cascade]
Ref: content_relations.target_content_item_id > content_items.id [delete: cascade]

Ref: practice_resources.content_item_id > content_items.id [delete: restrict]
Ref: practice_resources.provider_id > practice_providers.id [delete: restrict]

Ref: catalog_releases.domain_id > domains.id [delete: restrict]
Ref: catalog_releases.published_by > profiles.id [delete: set null]
Ref: catalog_release_versions.(domain_id, catalog_release_id) > catalog_releases.(domain_id, id) [delete: cascade]
Ref: catalog_release_versions.(domain_id, content_item_id) > content_items.(domain_id, id) [delete: restrict]
Ref: catalog_release_versions.(content_item_id, content_version_id) > content_versions.(content_item_id, id) [delete: restrict]

Ref: user_progress.user_id > profiles.id [delete: cascade]
Ref: user_progress.content_item_id > content_items.id [delete: restrict]

Ref: bookmarks.user_id > profiles.id [delete: cascade]
Ref: bookmarks.content_item_id > content_items.id [delete: restrict]

Ref: practice_attempts.user_id > profiles.id [delete: cascade]
Ref: practice_attempts.content_item_id > content_items.id [delete: restrict]
Ref: practice_attempts.provider_id > practice_providers.id [delete: restrict]
Ref: practice_attempts.practice_resource_id > practice_resources.id [delete: restrict]
Ref: practice_attempts.(practice_resource_id, content_item_id) > practice_resources.(id, content_item_id) [delete: restrict]
Ref: practice_attempts.(practice_resource_id, provider_id) > practice_resources.(id, provider_id) [delete: restrict]

Ref: user_notes.user_id > profiles.id [delete: cascade]
Ref: user_notes.content_item_id > content_items.id [delete: restrict]

Ref: activity_events.user_id > profiles.id [delete: cascade]
Ref: activity_events.content_item_id > content_items.id [delete: set null]

Ref: review_cards.user_id > profiles.id [delete: cascade]
Ref: review_cards.content_item_id > content_items.id [delete: restrict]
Ref: review_history.(review_card_id, user_id) > review_cards.(id, user_id) [delete: cascade]

Ref: devices.user_id > profiles.id [delete: cascade]
Ref: devices.id - device_user_sync_state.device_id [delete: cascade]
Ref: device_catalog_sync_state.device_id > devices.id [delete: cascade]
Ref: device_catalog_sync_state.domain_id > domains.id [delete: cascade]
Ref: device_catalog_sync_state.(domain_id, last_catalog_release_id) > catalog_releases.(domain_id, id) [delete: restrict]

Ref: sync_mutations.user_id > profiles.id [delete: cascade]
Ref: sync_mutations.(device_id, user_id) > devices.(id, user_id) [delete: cascade]

Ref: user_sync_counters.user_id > profiles.id [delete: cascade]
Ref: user_sync_change_log.user_id > profiles.id [delete: cascade]
Ref: catalog_sync_counters.domain_id > domains.id [delete: cascade]
Ref: catalog_sync_change_log.domain_id > domains.id [delete: cascade]

// ============================================================
// DIAGRAM GROUPS
// ============================================================

TableGroup "Identity & Authorization" {
  profiles
  roles
  profile_role_grants
}

TableGroup "Catalog & Taxonomy" {
  domains
  categories
  topics
  topic_categories
}

TableGroup "Content Platform" {
  content_items
  content_versions
  content_version_status_history
  content_blocks
  content_version_blocks
  content_item_categories
  content_item_topics
  content_relations
}

TableGroup "Practice" {
  practice_providers
  practice_resources
  practice_attempts
}

TableGroup "Learning State" {
  user_progress
  bookmarks
  user_notes
  activity_events
}

TableGroup "Recall" {
  review_cards
  review_history
}

TableGroup "Catalog Releases" {
  catalog_releases
  catalog_release_versions
}

TableGroup "Offline Sync" {
  devices
  device_user_sync_state
  device_catalog_sync_state
  sync_mutations
  user_sync_counters
  user_sync_change_log
  catalog_sync_counters
  catalog_sync_change_log
}
